# Compose-only defaults for local development.
# Do not store secrets in this file. Production should use /opt/metis-config/compose.env.

WEB_HOST_PORT=5173
API_HOST_PORT=8000
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
MAILHOG_SMTP_HOST_PORT=1025
MAILHOG_UI_HOST_PORT=8025

APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_FRONTEND_URL=http://127.0.0.1:5173
LOG_LEVEL=debug
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,localhost:8000,127.0.0.1:8000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

VITE_API_URL=/api
VITE_PROXY_TARGET=http://proxy
